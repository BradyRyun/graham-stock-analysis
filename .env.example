# Frontend (optional in dev — Vite proxies /api to the server)
VITE_BACKEND_URL=

# Server
PORT=3001
# Optional: restrict CORS to a single origin (localhost:* always allowed in dev)
# CORS_ORIGIN=http://localhost:5173
RISK_FREE_RATE=0.04
POLYGON_API_KEY=
# Option A: Google AI Studio API key
# GEMINI_API_KEY=

# Option B: Vertex AI service account (takes precedence when both are set)
# Path to your service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-central1

# Optional Gemini model for business profiles (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
